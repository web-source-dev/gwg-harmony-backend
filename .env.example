MONGODB_URI=mongodb://localhost:27017/gwg-pilot
PORT=4108
FRONTEND_URL=http://localhost:3108
ADMIN_PASSWORD=changeme_use_a_strong_password

# Email (Brevo — same as harmony4all.org backend)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=media@harmony4all.org
ADMIN_EMAIL=info@harmony4all.org

# SMS (Twilio — admin alerts only)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_twilio_messaging_service_sid
ADMIN_PHONE_NUMBER=+1XXXXXXXXXX

# ── Coursera cohort automation ──────────────────────────────
# Request API credentials from your Coursera account manager.
COURSERA_CLIENT_ID=your_coursera_client_id
COURSERA_CLIENT_SECRET=your_coursera_client_secret
COURSERA_ORG_ID=your_coursera_org_id
# After running: npm run coursera:auth (admin OAuth — required for learner data API)
# COURSERA_REFRESH_TOKEN=
# Optional: limit to one program
# COURSERA_PROGRAM_ID=
COURSERA_API_BASE=https://api.coursera.org
COURSERA_TOKEN_URL=https://api.coursera.com/oauth2/client_credentials/token
# Scope for Enterprise / For Business API (default applied if unset)
# COURSERA_SCOPE=access_business_api

# Google Sheet (share with service account email as Editor)
GOOGLE_SHEET_ID=1m3CRs-HFAfVNOsCsMZKui8CPrUVs2qBW3Y-Tp5U1Ejk
GOOGLE_SHEET_TAB=Learner Progress
# Path to JSON key file OR inline JSON string:
GOOGLE_APPLICATION_CREDENTIALS=./config/google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cohort rules
COHORT_START_DATE=2025-01-01
INACTIVITY_DAYS_THRESHOLD=7
REMINDER_COOLDOWN_DAYS=7

# Friday 12:00 PM cron (America/New_York)
ENABLE_COHORT_CRON=true
COHORT_CRON_SCHEDULE=0 12 * * 5
COHORT_CRON_TIMEZONE=America/New_York
